# CJC-CLINIC — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# If your PHP setup doesn't auto-load .env, set these in:
#   - Apache: SetEnv in httpd.conf or .htaccess
#   - Nginx+PHP-FPM: env[] in php-fpm pool config
#   - XAMPP: SetEnv in the VirtualHost block

DB_HOST=127.0.0.1
DB_NAME=cjc_clinic
DB_USER=cjc_app          # Use a dedicated DB user, NOT root
DB_PASS=CHANGE_ME        # Set a strong password here
DB_CHARSET=utf8mb4
